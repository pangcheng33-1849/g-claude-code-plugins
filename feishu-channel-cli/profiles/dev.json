{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "excludedCommands": ["docker", "docker-compose"],
    "filesystem": {
      "allowWrite": [
        "~/.claude/channels/feishu",
        "~/.claude/plugins",
        "~/.feishu-auth-cache",
        "/tmp",
        "/usr/local",
        "~/.npm",
        "~/.bun",
        "~/.cargo",
        "~/.pnpm-store",
        "~/.gitconfig",
        "~/.gitignore_global",
        "~/.ssh"
      ]
    },
    "network": {
      "allowedDomains": ["*.com", "*.org", "*.io", "*.net", "*.dev", "*.cn", "*.cc"]
    }
  },
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "mcp__plugin_feishu-channel_feishu__reply",
      "mcp__plugin_feishu-channel_feishu__react",
      "mcp__plugin_feishu-channel_feishu__edit_message",
      "mcp__plugin_feishu-channel_feishu__fetch_messages",
      "mcp__plugin_feishu-channel_feishu__download_resource",
      "mcp__plugin_feishu-channel_feishu__dismiss_ack",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(deno *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(mvn *)",
      "Bash(gradle *)",
      "Bash(gem *)",
      "Bash(bundle *)",
      "Bash(composer *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(ninja *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(lsof *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "Bash(swift *)",
      "Bash(pod *)",
      "Bash(adb *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(vite *)",
      "Bash(webpack *)"
    ],
    "deny": [
      "Edit(.claude/settings*)",
      "Write(.claude/settings*)",
      "Bash(rm -rf /)"
    ]
  }
}
