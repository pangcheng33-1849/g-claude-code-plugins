{
  "permissions": {
    "allow": [
      "Bash(gh repo:*)",
      "WebFetch(domain:www.npmjs.com)",
      "Bash(my-deploy-script *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(node *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(deno *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(cargo *)",
      "Bash(go *)",
      "Bash(mvn *)",
      "Bash(gradle *)",
      "Bash(gem *)",
      "Bash(bundle *)",
      "Bash(composer *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(make *)",
      "Bash(cmake *)",
      "Bash(ninja *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(lsof *)",
      "Bash(xcodebuild *)",
      "Bash(xcrun *)",
      "Bash(swift *)",
      "Bash(pod *)",
      "Bash(adb *)",
      "Bash(tsc *)",
      "Bash(eslint *)",
      "Bash(prettier *)",
      "Bash(vite *)",
      "Bash(webpack *)"
    ],
    "deny": [
      "Bash(rm -rf /home/*)",
      "Bash(rm -rf /)"
    ],
    "defaultMode": "dontAsk"
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "effortLevel": "high",
  "myCustomKey": "should-survive",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "excludedCommands": [
      "docker",
      "docker-compose"
    ],
    "filesystem": {
      "allowWrite": [
        "~/.claude/channels/feishu",
        "~/.claude/plugins",
        "~/.feishu-auth-cache",
        "/tmp",
        "/usr/local",
        "~/.npm",
        "~/.bun",
        "~/.cargo",
        "~/.pnpm-store",
        "~/.gitconfig",
        "~/.gitignore_global",
        "~/.ssh"
      ]
    },
    "network": {
      "allowedDomains": [
        "*"
      ]
    }
  }
}
